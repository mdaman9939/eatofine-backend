  name                              String                 @unique(map: "zones_name_unique")
  coordinates                       Unsupported("polygon")
  status                            Boolean                @default(true)
  created_at                        DateTime?              @db.Timestamp(0)
  updated_at                        DateTime?              @db.Timestamp(0)
  restaurant_wise_topic             String?
