generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

// NOTE: This datasource is here only because Prisma requires one to generate
// the client. We do NOT actually use it — every service routes to MongoDB
// via the USE_MONGO_* feature flags. The URL is hardcoded to a dummy so the
// build doesn't need any DATABASE_URL env var to be set.
datasource db {
  provider = "mysql"
  url      = "mysql://disabled:disabled@localhost:3306/disabled"
}

model account_transactions {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  from_type       String
  from_id         BigInt
  current_balance Decimal   @db.Decimal(24, 2)
  amount          Decimal   @db.Decimal(24, 2)
  method          String
  ref             String?
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
  type            String    @default("collected") @db.VarChar(20)
  created_by      String    @default("admin") @db.VarChar(20)
}

model add_ons {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name              String?
  price             Decimal   @default(0.00) @db.Decimal(24, 2)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  restaurant_id     BigInt    @db.UnsignedBigInt
  status            Boolean   @default(true)
  stock_type        String    @default("unlimited") @db.VarChar(20)
  addon_stock       Int       @default(0)
  sell_count        Int       @default(0)
  addon_category_id BigInt?   @db.UnsignedBigInt
}

model addon_categories {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @db.VarChar(255)
  status     Boolean   @default(true)
  slug       String?   @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model addon_settings {
  id              String    @id @db.Char(36)
  key_name        String?
  live_values     String?   @db.LongText
  test_values     String?   @db.LongText
  settings_type   String?   @db.VarChar(255)
  mode            String    @default("live") @db.VarChar(20)
  is_active       Boolean   @default(true)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
  additional_data String?   @db.LongText

  @@index([id], map: "payment_settings_id_index")
}

model admin_features {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title       String?   @db.VarChar(100)
  sub_title   String?   @db.VarChar(100)
  description String?   @db.Text
  image       String?   @db.VarChar(100)
  status      Boolean   @default(true)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model admin_roles {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @db.VarChar(100)
  modules    String?   @db.Text
  status     Boolean   @default(true)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model admin_special_criterias {
  title  String? @db.VarChar(100)
  image  String? @db.VarChar(100)
  status Boolean @default(true)

  @@ignore
}

model admin_testimonials {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name           String?   @db.VarChar(100)
  designation    String?   @db.VarChar(100)
  review         String?   @db.Text
  reviewer_image String?   @db.VarChar(255)
  company_image  String?   @db.VarChar(255)
  status         Boolean   @default(true)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
}

model admin_wallets {
  id                       BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  admin_id                 BigInt    @db.UnsignedBigInt
  total_commission_earning Decimal   @default(0.00) @db.Decimal(24, 2)
  digital_received         Decimal   @default(0.00) @db.Decimal(24, 2)
  manual_received          Decimal   @default(0.00) @db.Decimal(24, 2)
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
  delivery_charge          Decimal   @default(0.00) @db.Decimal(24, 2)
}

model admins {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  f_name         String?   @db.VarChar(100)
  l_name         String?   @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  email          String    @unique(map: "admins_email_unique") @db.VarChar(100)
  image          String?   @db.VarChar(100)
  password       String    @db.VarChar(100)
  remember_token String?   @db.VarChar(100)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  role_id        BigInt    @db.UnsignedBigInt
  zone_id        BigInt?   @db.UnsignedBigInt
  is_logged_in   Boolean   @default(true)
}

model advertisements {
  id                BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  restaurant_id     BigInt                  @db.UnsignedBigInt
  add_type          advertisements_add_type @default(restaurant_promotion)
  title             String?                 @db.VarChar(255)
  description       String?                 @db.Text
  start_date        DateTime                @db.Date
  end_date          DateTime                @db.Date
  pause_note        String?                 @db.Text
  cancellation_note String?                 @db.Text
  cover_image       String?                 @db.VarChar(255)
  profile_image     String?                 @db.VarChar(255)
  video_attachment  String?                 @db.VarChar(255)
  priority          Int?
  is_rating_active  Boolean                 @default(false)
  is_review_active  Boolean                 @default(false)
  is_paid           Boolean                 @default(false)
  is_updated        Boolean                 @default(false)
  created_by_id     BigInt                  @db.UnsignedBigInt
  created_by_type   String                  @db.VarChar(255)
  status            advertisements_status   @default(pending)
  created_at        DateTime?               @db.Timestamp(0)
  updated_at        DateTime?               @db.Timestamp(0)
}

model allergies {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  allergy    String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model allergy_food {
  id         BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  food_id    BigInt @db.UnsignedBigInt
  allergy_id BigInt @db.UnsignedBigInt
}

model allergy_item_campaign {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  item_campaign_id BigInt    @db.UnsignedBigInt
  allergy_id       BigInt    @db.UnsignedBigInt
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)

  @@index([allergy_id], map: "allergy_item_campaign_allergy_id_index")
  @@index([item_campaign_id], map: "allergy_item_campaign_item_campaign_id_index")
}

model analytic_scripts {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @db.VarChar(255)
  type       String?   @db.VarChar(255)
  script_id  String?   @db.Text
  script     String?   @db.LongText
  is_active  Boolean   @default(false)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model attributes {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String?   @db.VarChar(100)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model banners {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title      String
  type       String
  image      String?
  status     Boolean   @default(true)
  data       String
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  zone_id    BigInt    @db.UnsignedBigInt
}

model business_settings {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  key        String
  value      String?   @db.Text
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model cache {
  key        String @id @db.VarChar(255)
  value      String @db.MediumText
  expiration Int
}

model cache_locks {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration Int
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model campaign_restaurant {
  campaign_id     BigInt  @db.UnsignedBigInt
  restaurant_id   BigInt  @db.UnsignedBigInt
  campaign_status String? @default("pending") @db.VarChar(10)

  @@ignore
}

model campaigns {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title       String?
  image       String?   @db.VarChar(100)
  description String?   @db.Text
  status      Boolean   @default(true)
  admin_id    BigInt?   @db.UnsignedBigInt
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  start_date  DateTime? @db.Date
  end_date    DateTime? @db.Date
  start_time  DateTime? @db.Time(0)
  end_time    DateTime? @db.Time(0)
  slug        String?   @db.VarChar(255)
}

model carts {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id           BigInt    @db.UnsignedBigInt
  item_id           BigInt    @db.UnsignedBigInt
  is_guest          Boolean   @default(false)
  add_on_ids        String?   @db.Text
  add_on_qtys       String?   @db.Text
  item_type         String    @db.VarChar(255)
  price             Float
  quantity          Int
  variations        String?   @db.Text
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  variation_options String?   @db.Text
}

model cash_back_histories {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  cash_back_id      BigInt?   @db.UnsignedBigInt
  order_id          BigInt?   @db.UnsignedBigInt
  user_id           BigInt?   @db.UnsignedBigInt
  cashback_type     String    @db.VarChar(255)
  calculated_amount Float     @default(0.000)
  cashback_amount   Float     @default(0.000)
  min_purchase      Float     @default(0.000)
  max_discount      Float     @default(0.000)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model cash_backs {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title           String    @db.VarChar(255)
  customer_id     String?   @default("[\"all\"]") @db.VarChar(255)
  cashback_type   String    @db.VarChar(255)
  same_user_limit Int       @default(1)
  total_used      Int       @default(0)
  cashback_amount Float     @default(0.000)
  min_purchase    Float     @default(0.000)
  max_discount    Float     @default(0.000)
  start_date      DateTime? @db.Date
  end_date        DateTime? @db.Date
  status          Boolean   @default(true)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model categories {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name             String
  image            String    @default("def.png")
  parent_id        Int
  position         Int
  status           Boolean   @default(true)
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  priority         Int       @default(0)
  slug             String?   @db.VarChar(255)
  meta_title       String?   @db.VarChar(100)
  meta_description String?   @db.Text
  meta_image       String?   @db.VarChar(100)
  meta_data        String?   @db.LongText
}

model characteristic_restaurant {
  id                BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  restaurant_id     BigInt @db.UnsignedBigInt
