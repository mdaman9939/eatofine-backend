  taxable_type        String    @db.VarChar(255)
  taxable_id          BigInt    @db.UnsignedBigInt
  tax_id              BigInt    @db.UnsignedBigInt
  system_tax_setup_id BigInt    @db.UnsignedBigInt
  created_at          DateTime? @db.Timestamp(0)
  updated_at          DateTime? @db.Timestamp(0)
}

model taxes {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name         String    @db.VarChar(255)
  tax_rate     Float     @default(0.00000000)
  country_code String?   @db.VarChar(20)
  is_default   Boolean   @default(false)
  is_active    Boolean   @default(true)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)

  @@index([country_code], map: "taxes_country_code_index")
}

model time_logs {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  date         DateTime  @db.Date
  online       DateTime? @db.Time(0)
  offline      DateTime? @db.Time(0)
  working_hour Decimal   @default(0.000) @db.Decimal(23, 3)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  shift_id     BigInt?   @db.UnsignedBigInt
}

model track_deliverymen {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  order_id        BigInt?   @db.UnsignedBigInt
  delivery_man_id BigInt?   @db.UnsignedBigInt
  longitude       String?   @db.VarChar(20)
  latitude        String?   @db.VarChar(20)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model translations {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  translationable_type String    @db.VarChar(255)
  translationable_id   BigInt    @db.UnsignedBigInt
  locale               String    @db.VarChar(255)
  key                  String?   @db.VarChar(255)
  value                String?   @db.Text
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)

  @@index([locale], map: "translations_locale_index")
  @@index([translationable_id], map: "translations_translationable_id_index")
}

model user_infos {
