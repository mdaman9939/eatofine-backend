  updated_at      DateTime? @db.Timestamp(0)
}

model users {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  f_name               String?   @db.VarChar(100)
  l_name               String?   @db.VarChar(100)
  phone                String?   @unique(map: "users_phone_unique") @db.VarChar(255)
  email                String?   @db.VarChar(100)
  image                String?   @db.VarChar(100)
  is_phone_verified    Boolean   @default(false)
  email_verified_at    DateTime? @db.Timestamp(0)
  password             String?   @db.VarChar(100)
  auth_token           String?
  remember_token       String?   @db.VarChar(100)
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
  interest             String?
  cm_firebase_token    String?
  status               Boolean   @default(true)
  order_count          Int       @default(0)
  login_medium         String?
  social_id            String?
  zone_id              BigInt?   @db.UnsignedBigInt
  wallet_balance       Decimal   @default(0.000) @db.Decimal(24, 3)
  loyalty_point        Decimal   @default(0.000) @db.Decimal(24, 3)
  ref_code             String?   @unique(map: "users_ref_code_unique")
  ref_by               BigInt?   @db.UnsignedBigInt
  temp_token           String?   @db.VarChar(255)
  current_language_key String?   @default("en") @db.VarChar(255)
  is_email_verified    Boolean   @default(false)

  @@index([zone_id], map: "users_zone_id_index")
  @@index([auth_token], map: "idx_users_auth_token")
}

model variation_options {
