}

model characteristics {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  characteristic String    @db.VarChar(255)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
}

model contact_messages {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name          String    @db.VarChar(255)
  email         String    @db.VarChar(255)
  mobile_number String?   @db.VarChar(255)
  subject       String?   @db.VarChar(255)
  message       String    @db.Text
  reply         String?   @db.Text
  feedback      String?   @default("0") @db.VarChar(255)
  seen          Boolean?  @default(false)
  status        Boolean?  @default(true)
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
}

model conversations {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  sender_id            BigInt?   @db.UnsignedBigInt
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
  sender_type          String    @db.VarChar(255)
  receiver_id          BigInt    @db.UnsignedBigInt
  receiver_type        String    @db.VarChar(255)
  last_message_id      BigInt?   @db.UnsignedBigInt
  last_message_time    DateTime? @db.Timestamp(0)
  unread_message_count Int       @default(0)
}

model coupons {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title         String?
  code          String?   @unique(map: "coupons_code_unique") @db.VarChar(100)
  start_date    DateTime? @db.Date
  expire_date   DateTime? @db.Date
  min_purchase  Decimal   @default(0.00) @db.Decimal(24, 2)
  max_discount  Decimal   @default(0.00) @db.Decimal(24, 2)
  discount      Decimal   @default(0.00) @db.Decimal(24, 2)
  discount_type String    @default("percentage") @db.VarChar(15)
  coupon_type   String    @default("default")
  limit         Int?
  status        Boolean   @default(true)
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
  data          String?
  total_uses    BigInt?   @default(0)
  created_by    String?   @default("admin") @db.VarChar(50)
  customer_id   String?   @default("[\"all\"]") @db.VarChar(255)
  slug          String?   @db.VarChar(255)
  restaurant_id BigInt?   @db.UnsignedBigInt
}

model cuisine_restaurant {
  id            BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  restaurant_id BigInt @db.UnsignedBigInt
  cuisine_id    BigInt @db.UnsignedBigInt
}

model cuisines {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name             String    @db.VarChar(255)
  image            String?   @db.VarChar(255)
  status           Boolean   @default(true)
  slug             String?   @db.VarChar(255)
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  meta_title       String?   @db.VarChar(100)
  meta_description String?   @db.Text
  meta_image       String?   @db.VarChar(100)
  meta_data        String?   @db.LongText
}

model currencies {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  country         String?
  currency_code   String?
  currency_symbol String?
  exchange_rate   Decimal?  @db.Decimal(8, 2)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model customer_addresses {
  id                    BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  address_type          String    @db.VarChar(100)
  contact_person_number String    @db.VarChar(20)
  address               String?   @db.Text
  latitude              String?
  longitude             String?
  user_id               BigInt?   @db.UnsignedBigInt
  contact_person_name   String?   @db.VarChar(100)
  created_at            DateTime? @db.Timestamp(0)
  updated_at            DateTime? @db.Timestamp(0)
  zone_id               BigInt?   @db.UnsignedBigInt
  floor                 String?   @db.VarChar(255)
  road                  String?   @db.VarChar(255)
  house                 String?   @db.VarChar(255)
  is_default            Boolean   @default(false)

  @@index([user_id], map: "customer_addresses_user_id_index")
  @@index([zone_id], map: "customer_addresses_zone_id_index")
}

model d_m_reviews {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  delivery_man_id BigInt    @db.UnsignedBigInt
  user_id         BigInt    @db.UnsignedBigInt
  order_id        BigInt    @db.UnsignedBigInt
  comment         String?   @db.MediumText
  attachment      String?
  rating          Int       @default(0)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
  status          Boolean?  @default(true)
}

model data_settings {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  key        String    @db.VarChar(255)
  value      String?   @db.Text
  type       String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model delivery_histories {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  order_id        BigInt?   @db.UnsignedBigInt
  delivery_man_id BigInt?   @db.UnsignedBigInt
  time            DateTime? @db.DateTime(0)
  longitude       String?
  latitude        String?
  location        String?
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model delivery_man_devices {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  delivery_man_id   BigInt    @db.UnsignedBigInt
  device_id         String    @unique(map: "delivery_man_devices_device_id_unique") @db.VarChar(255)
  device_name       String?   @db.VarChar(255)
  biometric_token   String?   @db.VarChar(255)
  biometric_enabled Boolean   @default(false)
  last_login_at     DateTime? @db.Timestamp(0)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model delivery_man_shift {
  id              BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  delivery_man_id BigInt       @db.UnsignedBigInt
  shift_id        BigInt       @db.UnsignedBigInt
  created_at      DateTime?    @db.Timestamp(0)
  updated_at      DateTime?    @db.Timestamp(0)
  delivery_men    delivery_men @relation(fields: [delivery_man_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "delivery_man_shift_delivery_man_id_foreign")
  shifts          shifts       @relation(fields: [shift_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "delivery_man_shift_shift_id_foreign")

  @@index([delivery_man_id], map: "delivery_man_shift_delivery_man_id_foreign")
  @@index([shift_id], map: "delivery_man_shift_shift_id_foreign")
}

model delivery_man_wallets {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  delivery_man_id  BigInt    @db.UnsignedBigInt
  collected_cash   Decimal   @default(0.00) @db.Decimal(24, 2)
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  total_earning    Decimal   @default(0.00) @db.Decimal(24, 2)
  total_withdrawn  Decimal   @default(0.00) @db.Decimal(24, 2)
  pending_withdraw Decimal   @default(0.00) @db.Decimal(24, 2)
}

model delivery_men {
  id                   BigInt                          @id @default(autoincrement()) @db.UnsignedBigInt
  f_name               String?                         @db.VarChar(100)
  l_name               String?                         @db.VarChar(100)
  phone                String                          @unique(map: "delivery_men_phone_unique") @db.VarChar(20)
  email                String?                         @db.VarChar(100)
  identity_number      String?                         @db.VarChar(30)
  identity_type        String?                         @db.VarChar(50)
  identity_image       String                          @db.Text
  image                String?                         @db.VarChar(100)
  password             String                          @db.VarChar(100)
  auth_token           String?
  fcm_token            String?
  zone_id              BigInt?
  created_at           DateTime?                       @db.Timestamp(0)
  updated_at           DateTime?                       @db.Timestamp(0)
  status               Boolean                         @default(true)
  active               Boolean                         @default(true)
  earning              Boolean                         @default(true)
  current_orders       Int                             @default(0)
  type                 String                          @default("zone_wise")
  restaurant_id        BigInt?
  application_status   delivery_men_application_status @default(approved)
  order_count          Int                             @default(0) @db.UnsignedInt
  assigned_order_count Int                             @default(0) @db.UnsignedInt
  vehicle_id           BigInt?                         @db.UnsignedBigInt
  shift_id             BigInt?                         @db.UnsignedBigInt
  additional_data      String?                         @db.Text
  additional_documents String?                         @db.Text
  current_language_key String?                         @default("en") @db.VarChar(255)
  delivery_man_shift   delivery_man_shift[]
}

model disbursement_details {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  disbursement_id     BigInt    @db.UnsignedBigInt
  restaurant_id       BigInt?   @db.UnsignedBigInt
