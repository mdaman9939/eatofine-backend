# MongoDB Atlas — Phase 1 of MySQL → MongoDB migration
# Password is the LITERAL value as stored in Atlas (contains '%40' as 3 chars).
# We URL-encode at runtime when building the connection URI.
MONGO_USER="aman_admin"
MONGO_PASSWORD="Aman%40123456"
MONGO_DATABASE="eatofine"
MONGO_HOSTS="ac-wwhajfd-shard-00-00.5kgahgx.mongodb.net:27017,ac-wwhajfd-shard-00-01.5kgahgx.mongodb.net:27017,ac-wwhajfd-shard-00-02.5kgahgx.mongodb.net:27017"
MONGO_REPLICA_SET="atlas-fv6e0i-shard-0"
MONGO_AUTH_SOURCE="admin"

# Feature flags — when "1", route to MongoDB; when "0" (default), route to MySQL.
# These let us migrate module-by-module. Keep them all ON to run the whole
# backend off MongoDB Atlas; flip any to "0" for a quick rollback.
USE_MONGO_CATALOG="1"      # CatalogService — banners, categories, cuisines
USE_MONGO_AUTH="1"         # AuthService.adminLogin
USE_MONGO_ADMIN="1"        # AdminService — ~95 admin panel endpoints
USE_MONGO_BROWSE="1"       # BrowseService — mobile customer app: restaurants/foods
USE_MONGO_ORDER="1"        # OrderService — customer order placement + track + list
USE_MONGO_CUSTOMER="1"     # CustomerService — customer profile, addresses, cart
USE_MONGO_OPS="1"          # OpsService — vendor + delivery man order management
