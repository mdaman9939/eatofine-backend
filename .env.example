# ──────────────────────────────────────────────────────────────────
# Eatofine Backend API — environment template
# Copy this file to `.env` (locally) or set these vars in Render dashboard.
# ──────────────────────────────────────────────────────────────────

# MySQL connection. Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME
# Local example:  mysql://root:Superaip@127.0.0.1:3306/stackfood?connection_limit=10
# TiDB Cloud:     mysql://user.root:PASS@gateway01.region.tidbcloud.com:4000/stackfood?connection_limit=10&sslaccept=strict
DATABASE_URL="mysql://root:CHANGE_ME@127.0.0.1:3306/stackfood?connection_limit=10"

# Public URL where uploaded files are served. In production this should be
# your Cloudinary/S3 base URL, or your deployed API's /storage prefix.
STORAGE_BASE_URL="http://localhost:3000/storage"

# Server bind host + port. In Render, set PORT to 10000 (auto-injected).
NODE_HOST="0.0.0.0"
NODE_PORT="3000"

# JWT signing secret (use any long random string in production)
JWT_SECRET="change-me-to-something-long-and-random"

# Comma-separated list of allowed frontend origins for CORS.
# Local dev:  http://localhost:3001,http://127.0.0.1:3001
# Production: https://eatofine.vercel.app
CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"

# Optional: where uploaded files live on disk (used in local dev only)
# Render free tier has ephemeral disk — use Cloudinary for production.
# STORAGE_ROOT=/var/data/storage
