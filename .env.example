# ──────────────────────────────────────────────────────────────────
# Eatofine Backend API — environment template
# Copy this file to `.env` (locally) or set these vars in Render dashboard.
#
# Note: This backend runs 100% on MongoDB Atlas. No MySQL / DATABASE_URL
# needed anywhere. The Prisma client still exists in the codebase but is
# completely inert (lazy + every service routed to MongoDB via flags).
# ──────────────────────────────────────────────────────────────────

# ── MongoDB Atlas — primary (and only) database ───────────────────
MONGO_USER="aman_admin"
MONGO_PASSWORD="Aman%40123456"
MONGO_DATABASE="eatofine"
MONGO_HOSTS="ac-wwhajfd-shard-00-00.5kgahgx.mongodb.net:27017,ac-wwhajfd-shard-00-01.5kgahgx.mongodb.net:27017,ac-wwhajfd-shard-00-02.5kgahgx.mongodb.net:27017"
MONGO_REPLICA_SET="atlas-fv6e0i-shard-0"
MONGO_AUTH_SOURCE="admin"

# ── Server bind ──────────────────────────────────────────────────
# In Render, PORT is auto-injected. NODE_HOST stays as 0.0.0.0.
NODE_HOST="0.0.0.0"
NODE_PORT="3000"

# ── Auth / CORS ──────────────────────────────────────────────────
JWT_SECRET="change-me-to-something-long-and-random"

# Comma-separated list of allowed frontend origins for CORS.
# Local dev:  http://localhost:3001,http://127.0.0.1:3001
# Production: https://your-frontend.vercel.app
CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"

# ── Storage ──────────────────────────────────────────────────────
# Public URL where uploaded files are served. In production point this to
# Cloudinary / S3 or your deployed API's /storage prefix.
STORAGE_BASE_URL="http://localhost:3000/storage"

# ── Feature flags (route requests to MongoDB) ────────────────────
# All flags ON = 100% MongoDB, no MySQL connection ever opened.
USE_MONGO_CATALOG="1"
USE_MONGO_AUTH="1"
USE_MONGO_ADMIN="1"
USE_MONGO_BROWSE="1"
USE_MONGO_ORDER="1"
USE_MONGO_CUSTOMER="1"
USE_MONGO_OPS="1"
USE_MONGO_ENHANCEMENTS="1"
USE_MONGO_DOCUMENTS="1"
USE_MONGO_COMPLETION="1"
USE_MONGO_EXTRAS="1"
USE_MONGO_BUSINESS_SETTINGS="1"
USE_MONGO_CONFIG="1"

# ── Firebase Cloud Messaging (real-time push to restaurant/vendor) ──
# Enables instant "new order" push (sound + popup) on the restaurant app.
# Paste the FULL service-account JSON (one line) from Firebase Console →
# Project settings → Service accounts → Generate new private key.
# If left blank, the API still works — orders just appear via 15s polling.
FIREBASE_SERVICE_ACCOUNT=""
# Alternative to the JSON above — 3 separate vars (use ONE approach):
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""
